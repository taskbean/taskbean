# Default: auto-detect text, LF line endings
* text=auto eol=lf

# PowerShell scripts: stored as-is with CRLF. Windows PowerShell 5.1 needs
# a UTF-8 BOM to correctly decode non-ASCII characters in .ps1 files — the
# BOM is enforced by .editorconfig (charset=utf-8-bom) in editors and by
# .github/workflows/launcher.yml (assert EF BB BF) in CI.
*.ps1 text eol=crlf

# Windows shell scripts: always CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
