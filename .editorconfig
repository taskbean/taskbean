root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.{ps1,cmd,bat}]
end_of_line = crlf

# Windows PowerShell 5.1 requires a UTF-8 BOM to correctly decode non-ASCII
# characters in .ps1 files — see .gitattributes for the matching git rule.
[*.ps1]
charset = utf-8-bom

[Makefile]
indent_style = tab
